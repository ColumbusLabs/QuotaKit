    "Free mode shows one synced provider. Pro unlocks all providers you've connected, plus widgets, cost history, sharing, and alerts.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Free mode shows one synced provider. Pro unlocks all providers you've connected, plus widgets, cost history, sharing, and alerts."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Free モードでは同期済みプロバイダーを 1 つ表示します。Pro では接続済みのすべてのプロバイダーに加えて、ウィジェット、コスト履歴、共有、アラートをアンロックできます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Free 模式显示一个已同步的提供商。Pro 可解锁你已连接的所有提供商，以及小组件、成本历史、分享和提醒。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Free 模式顯示一個已同步的提供商。Pro 可解鎖你已連接的所有提供商，以及小工具、成本歷史、分享和提醒。"
          }
        }
      }
    },
    "Remote guardrails — Columbus Labs can now update safe setup links, announcements, and feature kill switches over the air while native app changes still go through TestFlight/App Store.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remote guardrails — Columbus Labs can now update safe setup links, announcements, and feature kill switches over the air while native app changes still go through TestFlight/App Store."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リモートガードレール — Columbus Labs は安全なセットアップリンク、お知らせ、機能停止スイッチを OTA で更新できます。ネイティブアプリの変更は引き続き TestFlight/App Store 経由です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "远程护栏 — Columbus Labs 现在可以通过 OTA 更新安全的设置链接、公告和功能停用开关；原生应用更改仍会通过 TestFlight/App Store 发布。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "遠端護欄 — Columbus Labs 現在可以透過 OTA 更新安全的設定連結、公告和功能停用開關；原生 App 變更仍會透過 TestFlight/App Store 發佈。"
          }
        }
      }
    },
