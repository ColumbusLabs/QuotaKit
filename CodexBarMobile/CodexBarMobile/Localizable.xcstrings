        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 个模拟 provider 来自 Mac。在 Mac QuotaKit → 设置 → Mobile → Debug · Mock Provider Data 关闭后，iPhone 会在约 30 秒内更新。"
          }
