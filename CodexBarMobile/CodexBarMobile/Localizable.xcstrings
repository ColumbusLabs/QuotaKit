    "%lld synthetic providers from Mac · toggle off in Mac Settings → Mobile → Debug": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld synthetic providers from Mac · toggle off in Mac Settings → Mobile → Debug"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac から %lld 個の合成プロバイダー · Mac の設定 → Mobile → Debug でオフに切り替え"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 个模拟 provider 来自 Mac · 在 Mac 设置 → Mobile → Debug 关闭"
