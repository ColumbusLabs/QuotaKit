    "An in-app Release Notes page that shows the latest update first and keeps older versions collapsed below.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An in-app Release Notes page that shows the latest update first and keeps older versions collapsed below."
