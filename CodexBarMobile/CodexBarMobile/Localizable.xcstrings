    "A dedicated Cost tab with provider share, model mix, service mix, and 30-day spend analysis.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A dedicated Cost tab with provider share, model mix, service mix, and 30-day spend analysis."
