          "stringUnit": {
            "state": "translated",
            "value": "下拉刷新时会先请求 iCloud 同步，再读取最新数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下拉重新整理時會先請求 iCloud 同步，再讀取最新資料。"
          }
        }
      }
    },
    "Purchased credits": {
