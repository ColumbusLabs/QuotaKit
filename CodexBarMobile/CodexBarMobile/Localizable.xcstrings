          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "警告プッシュ通知の利用には macOS 用 QuotaKit 0.25.2 以降が必要です。新プロバイダーは 0.25.1 から利用できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
