    "Stranded Mock cards from a previous Mac session no longer linger after you toggle mock injection off. Mac auto-cleans them within ~1 minute.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stranded Mock cards from a previous Mac session no longer linger after you toggle mock injection off. Mac auto-cleans them within ~1 minute."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前回の Mac セッションが残したモックカードは、モック注入をオフにすると約 1 分以内に Mac が自動削除します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "之前 Mac 进程留下的 Mock 卡片，关闭 mock 注入后会在约 1 分钟内由 Mac 自动清理掉，不再永久残留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "之前 Mac 行程留下的 Mock 卡片，關閉 mock 注入後會在約 1 分鐘內由 Mac 自動清理，不再永久殘留。"
