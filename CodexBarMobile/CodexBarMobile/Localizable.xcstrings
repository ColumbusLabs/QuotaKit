    "Public Columbus Labs configuration for safe OTA guardrails. It cannot change app code or access provider credentials.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Public Columbus Labs configuration for safe OTA guardrails. It cannot change app code or access provider credentials."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "安全な OTA ガードレール用の Columbus Labs 公開設定です。アプリコードの変更やプロバイダー認証情報へのアクセスはできません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Columbus Labs 的公开配置仅用于安全的 OTA 护栏。它不能更改应用代码，也不能访问服务商凭据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Columbus Labs 的公開設定僅用於安全的 OTA 護欄。它不能變更 App 程式碼，也不能存取服務商憑證。"
          }
        }
      }
    },
