# Local-only QuotaKit release config. Copy to `.quotakit-release.local.env` or,
# preferably, store as `~/.quotakit-secrets/quotakit-release.env`.
#
# This file is intentionally not sourced unless it exists locally.
# Never commit real App Store Connect keys, issuer IDs, P8 contents, or
# Sparkle private keys.

APP_STORE_CONNECT_KEY_ID=YOUR_KEY_ID
APP_STORE_CONNECT_ISSUER_ID=YOUR_ISSUER_ID_UUID
APP_STORE_CONNECT_API_KEY_FILE=$HOME/.quotakit-secrets/AuthKey_YOUR_KEY_ID.p8
SPARKLE_PRIVATE_KEY_FILE=$HOME/.quotakit-secrets/sparkle_ed25519.key
APP_IDENTITY="Developer ID Application: QuotaKit (YOURTEAMID)"
APP_TEAM_ID=YOURTEAMID
QUOTAKIT_TEAM_ID=YOURTEAMID
