MAC_RELEASE_APP_NAME=QuotaKit
MAC_RELEASE_REPO=ColumbusLabs/QuotaKit
MAC_RELEASE_BUNDLE_ID=com.columbuslabs.quotakit.mac
MAC_RELEASE_VERSION_FILE=version.env
MAC_RELEASE_APPCAST=appcast.xml
MAC_RELEASE_SOURCE_FILES='Scripts/release_artifacts.sh'
MAC_RELEASE_SUPUBLIC_ED_KEY=
# QuotaKit must use a QuotaKit-owned Sparkle signing key. Keep private keys out
# of the repository; provide SPARKLE_PRIVATE_KEY_FILE from a local ignored env.
MAC_RELEASE_SIGNING_KEY_FILE=

MAC_RELEASE_APP_ZIP='QuotaKit-macos-universal-${MARKETING_VERSION}.zip'
MAC_RELEASE_DSYM_ZIP='QuotaKit-macos-universal-${MARKETING_VERSION}.dSYM.zip'
MAC_RELEASE_ARTIFACT_PREFIX='QuotaKit-macos-[A-Za-z0-9_+-]+-'
MAC_RELEASE_FEED_URL='https://raw.githubusercontent.com/ColumbusLabs/QuotaKit/main/appcast.xml'
MAC_RELEASE_DOWNLOAD_URL_PREFIX='https://github.com/ColumbusLabs/QuotaKit/releases/download/v${MARKETING_VERSION}/'

MAC_RELEASE_PRECHECK='swiftformat Sources Tests >/dev/null && swiftlint --strict && swift test --enable-xctest --disable-swift-testing && swift test --enable-swift-testing --disable-xctest --no-parallel'
MAC_RELEASE_PACKAGE_CMD='Scripts/sign-and-notarize.sh'
MAC_RELEASE_TAG_SIGNED=1
MAC_RELEASE_TAG_FORCE=1
MAC_RELEASE_GENERATE_APPCAST_ARGS='--maximum-deltas 0'
MAC_RELEASE_EXTRA_ASSET_WAIT_SECONDS=3600
MAC_RELEASE_EXTRA_ASSET_WAIT_INTERVAL=30
MAC_RELEASE_EXTRA_ASSET_PATTERNS='^QuotaKitCLI-v${MARKETING_VERSION}-macos-arm64\.tar\.gz$
^QuotaKitCLI-v${MARKETING_VERSION}-macos-arm64\.tar\.gz\.sha256$
^QuotaKitCLI-v${MARKETING_VERSION}-macos-x86_64\.tar\.gz$
^QuotaKitCLI-v${MARKETING_VERSION}-macos-x86_64\.tar\.gz\.sha256$
^QuotaKitCLI-v${MARKETING_VERSION}-linux-aarch64\.tar\.gz$
^QuotaKitCLI-v${MARKETING_VERSION}-linux-aarch64\.tar\.gz\.sha256$
^QuotaKitCLI-v${MARKETING_VERSION}-linux-x86_64\.tar\.gz$
^QuotaKitCLI-v${MARKETING_VERSION}-linux-x86_64\.tar\.gz\.sha256$'
